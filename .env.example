# Database Configuration
# For local running without Docker: postgresql://postgres:postgres@localhost:5432/onyx
# For Docker running: postgresql://postgres:postgres@db:5432/onyx
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/onyx

# S3 / MinIO Configuration
# For local running: http://localhost:9000
# For Docker running: http://minio:9000
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=onyx-assets

# Environment Configuration
ENVIRONMENT=development
PORT=8000
